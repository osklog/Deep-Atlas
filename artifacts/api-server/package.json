{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx ./src/index.ts",
    "build": "tsx ./build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/json-extract.test.ts",
    "test:integration": "vitest run src/__tests__/routes.test.ts",
    "test:watch": "vitest",
    "verify": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.27.3",
    "supertest": "^7.2.2",
    "tsx": "catalog:",
    "vitest": "^4.0.18"
  }
}
